{
  "$schema": "https://json.schemastore.org/kiro-agent.json",
  "name": "spring-coach",
  "description": "Spring framework coach — guides internals understanding, never gives copy-paste configs",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash"
  ],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": ["./**"]
    },
    "fs_write": {
      "allowedPaths": ["./docs/spring/**"]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://.kiro/steering/spring-coach.md"
  ]
}
