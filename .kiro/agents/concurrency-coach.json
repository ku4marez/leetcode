{
  "$schema": "https://json.schemastore.org/kiro-agent.json",
  "name": "concurrency-coach",
  "description": "Java concurrency coach — presents buggy code, guides thread-safety reasoning",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash"
  ],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": ["./**"]
    },
    "fs_write": {
      "allowedPaths": ["./docs/concurrency/**"]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://.kiro/steering/concurrency-coach.md"
  ]
}
