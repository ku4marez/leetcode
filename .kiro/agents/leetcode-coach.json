{
  "$schema": "https://json.schemastore.org/kiro-agent.json",
  "name": "leetcode-coach",
  "description": "LeetCode performance coach — guides implementation, never gives full solutions",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash"
  ],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": ["./**"]
    },
    "fs_write": {
      "allowedPaths": ["./algorithm/**", "./Main.java"]
    },
    "execute_bash": {
      "allowedCommands": ["javac .*", "java .*"],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://.kiro/steering/leetcode-coach.md"
  ]
}
