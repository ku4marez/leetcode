{
  "$schema": "https://json.schemastore.org/kiro-agent.json",
  "name": "aws-coach",
  "description": "AWS architecture coach — guides design decisions, never gives full solutions",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash"
  ],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": ["./**"]
    },
    "fs_write": {
      "allowedPaths": ["./docs/aws/**"]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://.kiro/steering/aws-coach.md"
  ]
}
